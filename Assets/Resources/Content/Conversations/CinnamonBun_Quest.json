        {
          "ID": "Accepted",
          "Text": "Oh, bless you! The gremlin skittered off east — the keepsake can't be far from wherever it's gotten to. Come back when it's done.",
          "Choices": [
            { "Text": "I'm on it.", "Target": "End" }
          ]
        },
        {
          "ID": "Status",
