              "Target": "Accepted",
              "Predicates": [
                { "Key": "IfQuestNotStarted", "Value": "CinnamonBunFavor" }
              ],
              "Actions": [
                { "Key": "StartQuest", "Value": "CinnamonBunFavor" }
              ]
            },
            {
              "Text": "[Status] Still working on it.",
              "Target": "Status",
              "Predicates": [
                { "Key": "IfQuestStage", "Value": "CinnamonBunFavor:errands" }
              ]
            },
            {
              "Text": "[Report] The keepsake's safe and the gremlin's gone.",
              "Target": "Thanks",
              "Predicates": [
                { "Key": "IfQuestStage", "Value": "CinnamonBunFavor:report" }
              ],
              "Actions": [
                { "Key": "CompleteQuest", "Value": "CinnamonBunFavor" },
                { "Key": "AwardXP", "Value": "250" },
                { "Key": "GiveDrams", "Value": "100" }
